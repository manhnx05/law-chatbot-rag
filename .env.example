# Law Chatbot RAG Environment Configuration

# Model Configuration
EMBEDDING_MODEL=bkai-foundation-models/vietnamese-bi-encoder
LLM_MODEL=llama3.2:1b

# Ollama Configuration
OLLAMA_URL=http://localhost:11434

# Logging
LOG_LEVEL=INFO

# API Configuration (Optional - leave empty to disable authentication)
API_KEY=
ALLOWED_ORIGINS=*

# Rate Limiting (requests per minute)
SEARCH_RATE_LIMIT=30
QUERY_RATE_LIMIT=10
